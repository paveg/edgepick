---
import { apiFetch } from "../../../../lib/api";

const { brandSlug, modelSlug } = Astro.params;

try {
  const res = await apiFetch(`/models/${brandSlug}/${modelSlug}`);
  if (res.ok) {
    const model = await res.json();
    return Astro.redirect(`/snowboard/${brandSlug}/${modelSlug}/${model.season}`, 302);
  }
} catch {
  // fall through to 404
}

return new Response("Not Found", { status: 404 });
---
