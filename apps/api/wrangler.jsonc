{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "edgepick-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-14",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "edgepick-db",
      "database_id": "local",
      "migrations_dir": "../../packages/db/drizzle",
    },
  ],
}
